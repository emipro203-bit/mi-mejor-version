generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
}

model Habit {
  id          String     @id @default(cuid())
  userId      String?
  name        String
  description String?
  icon        String?
  streak      Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  logs        HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime @db.Date
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String?
  date      DateTime @db.Date
  cups      Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model NegocioMetric {
  id              String   @id @default(cuid())
  userId          String?
  date            DateTime @db.Date
  ventas          Float    @default(0)
  pedidos         Int      @default(0)
  igFollowers     Int      @default(0)
  tiktokFollowers Int      @default(0)
  waContacts      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, date])
}

model RunSession {
  id          String   @id @default(cuid())
  userId      String?
  date        DateTime @db.Date
  distanceKm  Float
  durationMin Float
  avgHr       Int?
  zone        String?
  type        String   @default("Easy")
  notes       String?
  createdAt   DateTime @default(now())
}

model SleepLog {
  id          String   @id @default(cuid())
  userId      String?
  date        DateTime @db.Date
  bedtime     String
  wakeTime    String
  hours       Float
  quality     Int      @default(3)
  bodyBattery Int?
  stressScore Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String?
  name         String
  area         String
  currentValue Float    @default(0)
  targetValue  Float
  unit         String
  deadline     DateTime
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TradingModule {
  id     String  @id @default(cuid())
  userId String?
  number Int
  name   String
  done   Boolean @default(false)

  @@unique([userId, number])
}

model TradingNote {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  date      DateTime @db.Date
  color     String   @default("#C9A84C")
  type      String   @default("event")
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badge      String
  unlockedAt DateTime @default(now())

  @@unique([userId, badge])
}
